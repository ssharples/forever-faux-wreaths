# Convex Configuration
# Get these values from your Convex dashboard: https://dashboard.convex.dev

# Deployment identifier (used by npx convex dev)
CONVEX_DEPLOYMENT=dev:your-deployment-id

# Public Convex URL (required for client-side queries)
NEXT_PUBLIC_CONVEX_URL=https://your-deployment-id.convex.cloud

# Public site URL for metadata/canonical URLs
NEXT_PUBLIC_SITE_URL=https://foreverfauxwreaths.co.uk

# Site URL used by Stripe checkout success/cancel redirects
SITE_URL=https://foreverfauxwreaths.co.uk

# Stripe secret key used by Convex checkout session creation
STRIPE_SECRET_KEY=sk_test_your_secret_key

# Stripe webhook signing secret used by Convex webhook verification
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Resend API key for transactional emails
RESEND_API_KEY=re_your_resend_api_key

# Verified sender email for customer/admin notifications
RESEND_FROM_EMAIL=Forever Faux Wreaths <orders@foreverfauxwreaths.co.uk>

# Optional Stripe publishable key for future client-side card features
# STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
